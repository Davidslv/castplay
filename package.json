{
  "name": "castplay",
  "version": "1.0.0",
  "description": "A tiny, self-contained asciinema-cast player. No dependencies, no CDN, no build step.",
  "keywords": [
    "asciinema",
    "asciicast",
    "terminal",
    "player",
    "ansi",
    "presentation",
    "slides",
    "vanilla-js",
    "zero-dependencies"
  ],
  "homepage": "https://github.com/Davidslv/castplay#readme",
  "bugs": {
    "url": "https://github.com/Davidslv/castplay/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Davidslv/castplay.git"
  },
  "license": "MIT",
  "author": "David Silva (https://github.com/Davidslv)",
  "type": "commonjs",
  "main": "castplay.js",
  "exports": {
    ".": "./castplay.js"
  },
  "files": [
    "castplay.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test",
    "lint": "npm run lint:syntax && npm run lint:js && npm run lint:format && npm run lint:md && npm run lint:docs && npm run lint:casts",
    "lint:syntax": "node --check castplay.js",
    "lint:js": "eslint .",
    "lint:format": "prettier --check .",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:docs": "sh scripts/check-docs.sh",
    "lint:casts": "node scripts/check-casts.js",
    "format": "prettier --write .",
    "txt2cast": "node tools/txt-to-cast.js",
    "gate": "npm run lint && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^15.15.0",
    "markdownlint-cli2": "^0.14.0",
    "prettier": "^3.9.4"
  }
}
